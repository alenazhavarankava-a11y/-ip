<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Где взять ресурс сегодня</title>

<style>
:root{
    --bone:#F0EBE0;
    --black:#1A1A1A;
    --burgundy:#7D1B2A;
    --anthracite:#2A2A2A;
    --white:#ffffff;
}

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    background:var(--bone);
    color:var(--black);
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
    line-height:1.6;
    min-height:100vh;
}

.container{
    width:92%;
    max-width:700px;
    margin:0 auto;
    padding:40px 0 60px;
}

.header{
    text-align:center;
    margin-bottom:40px;
}

.sparkle{
    font-size:30px;
    margin-bottom:15px;
}

h1{
    font-family:"Palatino Linotype","Book Antiqua",Georgia,serif;
    font-size:40px;
    color:var(--burgundy);
    margin-bottom:15px;
    font-weight:600;
}

.subtitle{
    color:var(--anthracite);
    font-size:17px;
    max-width:500px;
    margin:0 auto;
}

.states{
    display:grid;
    gap:14px;
    margin-bottom:30px;
}

.state{
    background:rgba(255,255,255,0.6);
    border:1px solid rgba(125,27,42,0.2);
    border-radius:18px;
    padding:18px;
    cursor:pointer;
    transition:all .25s ease;
    font-size:16px;
}

.state:hover{
    border-color:var(--burgundy);
    transform:translateY(-2px);
}

.state.active{
    background:var(--burgundy);
    color:white;
    border-color:var(--burgundy);
}

button{
    width:100%;
    background:var(--burgundy);
    color:white;
    border:none;
    border-radius:18px;
    padding:18px;
    font-size:18px;
    cursor:pointer;
    transition:.3s;
    font-family:inherit;
}

button:hover{
    opacity:.92;
}

button:active{
    transform:scale(.98);
}

.result{
    display:none;
    background:var(--white);
    border-radius:26px;
    padding:30px;
    margin-top:35px;
    box-shadow:0 12px 35px rgba(0,0,0,0.08);
    animation:fade .5s ease;
}

@keyframes fade{
    from{
        opacity:0;
        transform:translateY(20px);
    }
    to{
        opacity:1;
        transform:translateY(0);
    }
}

.card-name{
    font-family:"Palatino Linotype","Book Antiqua",Georgia,serif;
    color:var(--burgundy);
    font-size:32px;
    margin-bottom:25px;
    text-align:center;
}

.block{
    margin-bottom:25px;
}

.block-title{
    color:var(--burgundy);
    font-weight:700;
    margin-bottom:8px;
}

.reminder{
    background:var(--bone);
    border-left:4px solid var(--burgundy);
    border-radius:14px;
    padding:18px;
    margin-top:30px;
}

.again-btn{
    margin-top:30px;
}

.footer{
    margin-top:60px;
    border-top:1px solid rgba(125,27,42,0.2);
    padding-top:35px;
    text-align:center;
}

.footer p{
    margin-bottom:16px;
}

.footer a{
    color:var(--burgundy);
    text-decoration:none;
    font-weight:600;
}

.footer a:hover{
    text-decoration:underline;
}

.small{
    color:#666;
    font-size:14px;
    margin-top:20px;
}

@media (max-width:600px){

    .container{
        width:90%;
        padding-top:30px;
    }

    h1{
        font-size:32px;
    }

    .subtitle{
        font-size:16px;
    }

    .result{
        padding:24px;
    }

    .card-name{
        font-size:28px;
    }

    button{
        font-size:17px;
    }
}
</style>
</head>

<body>

<div class="container">

    <div class="header">
        <div class="sparkle">✨</div>

        <h1>Где взять ресурс сегодня</h1>

        <p class="subtitle">
            Ежедневное послание для женщин, которые устали всё тянуть на себе и ищут опору.
        </p>
    </div>

    <div class="states">
        <div class="state">Устала и без сил</div>
        <div class="state">Тревожусь и много думаю</div>
        <div class="state">Запуталась и не понимаю, что делать</div>
        <div class="state">Всё раздражает</div>
        <div class="state">Хочу перемен, но боюсь</div>
        <div class="state">Мне просто нужна поддержка</div>
    </div>

    <button id="showCardBtn">
        ✨ Получить послание
    </button>

    <div class="result" id="result">

        <div class="card-name" id="cardName"></div>

        <div class="block">
            <div class="block-title">Послание</div>
            <div id="message"></div>
        </div>

        <div class="block">
            <div class="block-title">Вопрос для размышления</div>
            <div id="question"></div>
        </div>

        <div class="block">
            <div class="block-title">Маленькое действие на сегодня</div>
            <div id="action"></div>
        </div>

        <div class="reminder">
            💫 Вы не сломаны.<br>
            Вы просто проходите свой этап перемен.
        </div>

        <div class="again-btn">
            <button id="againBtn">
                ✨ Получить ещё одно послание
            </button>
        </div>

    </div>

    <div class="footer">

        <p>
            Хотите глубже?<br>
            Иногда один честный разговор помогает увидеть то, что вы не замечали годами.
        </p>

        <p>
            ✍️ Напишите мне:<br>
            <a href="https://t.me/AlenaZhavarankava" target="_blank">
                @AlenaZhavarankava
            </a>
        </p>

        <p>
            ✨ Больше подсказок, астропрогнозов и практик:
        </p>

        <p>
            <a href="https://t.me/Lerchetaro" target="_blank">
                Перейти в канал
            </a>
        </p>

        <div class="small">
            С любовью и заботой,<br>
            Елена Жаворонкова
        </div>

    </div>

</div>

<script>
const cards = [
{
card:"Императрица",
message:"Сегодня ваш главный ресурс — забота о себе. Вам не нужно всё держать под контролем.",
question:"Где я снова ставлю чужие потребности выше своих?",
action:"Сделайте сегодня что-то приятное только для себя."
},
{
card:"Сила",
message:"Вы гораздо сильнее, чем думаете. Не ищите опору вовне — она уже есть внутри вас.",
question:"Где я перестала доверять себе?",
action:"Вспомните три ситуации, когда вы справились, несмотря ни на что."
},
{
card:"Звезда",
message:"Даже если сейчас темно, надежда уже появилась. Не отказывайтесь от своей мечты.",
question:"Во что я перестала верить?",
action:"Запишите три желания без ограничений."
},
{
card:"Умеренность",
message:"Ваш ресурс сегодня — замедление. Не всё нужно решать прямо сейчас.",
question:"Где я живу на пределе своих сил?",
action:"Найдите хотя бы 20 минут тишины только для себя."
},
{
card:"Колесо Фортуны",
message:"Жизнь готовит перемены. Не цепляйтесь за то, что уже завершилось.",
question:"Что давно просится в моей жизни на обновление?",
action:"Сделайте один маленький шаг в сторону нового."
},
{
card:"Отшельник",
message:"Ответы, которые вы ищете, уже есть внутри вас.",
question:"Что я давно знаю, но боюсь признать?",
action:"Проведите сегодня 15 минут без телефона и внешнего шума."
},
{
card:"Башня",
message:"Что-то разрушается не против вас, а ради вас.",
question:"За что я держусь только из страха?",
action:"Отпустите сегодня одну ненужную обязанность."
},
{
card:"Мир",
message:"Вы завершаете важный этап жизни. Позвольте себе увидеть, как далеко вы уже пришли.",
question:"Что пора отпустить с благодарностью?",
action:"Подведите итоги последних месяцев и похвалите себя."
},
{
card:"Маг",
message:"У вас уже есть всё необходимое для следующего шага.",
question:"Почему я сомневаюсь в своих возможностях?",
action:"Сделайте сегодня то, что давно откладывали."
},
{
card:"Солнце",
message:"Ваш ресурс сегодня — в радости, лёгкости и простых удовольствиях.",
question:"Что делает меня по-настоящему живой?",
action:"Подарите себе маленькую радость без чувства вины."
},
{
card:"Верховная Жрица",
message:"Не торопите события. Сейчас время прислушаться к своей интуиции.",
question:"Какой внутренний голос я давно игнорирую?",
action:"Запишите первую мысль, которая придёт вам в голову после этого вопроса."
},
{
card:"Влюблённые",
message:"Сегодня важно выбирать себя и свои настоящие желания.",
question:"Где я живу не своей жизнью?",
action:"Спросите себя: чего хочу именно я?"
}
];

const states = document.querySelectorAll(".state");

states.forEach(item=>{
    item.addEventListener("click",()=>{
        states.forEach(el=>el.classList.remove("active"));
        item.classList.add("active");
    });
});

function showCard(){

    const randomCard = cards[Math.floor(Math.random() * cards.length)];

    document.getElementById("cardName").textContent = randomCard.card;
    document.getElementById("message").textContent = randomCard.message;
    document.getElementById("question").textContent = randomCard.question;
    document.getElementById("action").textContent = randomCard.action;

    const result = document.getElementById("result");
    result.style.display = "block";

    result.scrollIntoView({
        behavior:"smooth",
        block:"start"
    });
}

document.getElementById("showCardBtn").addEventListener("click", showCard);
document.getElementById("againBtn").addEventListener("click", showCard);
</script>

</body>
</html>
